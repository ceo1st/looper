{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://looper.dev/schemas/sweeper-proposal-v2.json",
  "title": "Looper Sweeper Proposal v2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "decision", "category", "confidenceScore", "summary", "rationale"],
  "properties": {
    "schemaVersion": {"type": "integer", "const": 2},
    "decision": {"type": "string", "enum": ["no_action", "warn", "close", "cancel", "stale_proposal"]},
    "category": {"type": "string", "enum": ["none", "stale", "already_fixed", "unrelated", "superseded", "abandoned_pr", "route_security"]},
    "confidenceScore": {"type": "integer", "minimum": 0, "maximum": 100},
    "summary": {"type": "string", "minLength": 1},
    "rationale": {"type": "string", "minLength": 1},
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "bundlePath"],
        "properties": {
          "kind": {"type": "string"},
          "bundlePath": {"type": "string", "minLength": 1},
          "id": {"type": "integer"},
          "number": {"type": "integer"}
        }
      }
    },
    "markerUUID": {"type": "string", "minLength": 1}
  }
}
