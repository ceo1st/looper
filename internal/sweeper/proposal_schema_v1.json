{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://looper.dev/schemas/sweeper-proposal-v1.json",
  "title": "Looper Sweeper Proposal v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "decision",
    "category",
    "confidenceScore",
    "summary",
    "rationale"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "decision": {
      "type": "string",
      "enum": ["no_action", "warn", "close", "cancel", "stale_proposal"]
    },
    "category": {
      "type": "string",
      "enum": ["none", "stale", "already_fixed", "unrelated", "superseded", "abandoned_pr", "route_security"]
    },
    "confidenceScore": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "rationale": {
      "type": "string",
      "minLength": 1
    },
    "markerUUID": {
      "type": "string",
      "minLength": 1
    }
  }
}
