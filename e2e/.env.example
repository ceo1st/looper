# Copy this file to e2e/.env for local/manual live e2e runs.
# Never commit e2e/.env; it contains a live Forgejo token.

export LOOPER_E2E_FORGEJO=1
export LOOPER_E2E_FORGEJO_BASE_URL=https://code.powerformer.net
export LOOPER_E2E_FORGEJO_SANDBOX_REPO=core/looper-sandbox
export LOOPER_E2E_FORGEJO_TOKEN='replace-with-forgejo-token'
